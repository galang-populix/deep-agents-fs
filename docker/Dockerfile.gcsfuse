FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    GCSFUSE_MOUNT_FLAGS="--implicit-dirs --foreground"

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    fuse3 \
    gnupg \
    lsb-release \
    util-linux \
    && rm -rf /var/lib/apt/lists/*

RUN export GCSFUSE_REPO="gcsfuse-$(lsb_release -c -s)" \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
    | gpg --dearmor -o /etc/apt/keyrings/cloud.google.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt ${GCSFUSE_REPO} main" \
    > /etc/apt/sources.list.d/gcsfuse.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gcsfuse \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md /app/
COPY modules /app/modules

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir . \
    && mkdir -p /mnt/gcsfuse

COPY docker/entrypoint.gcsfuse.sh /app/docker/entrypoint.gcsfuse.sh

RUN chmod +x /app/docker/entrypoint.gcsfuse.sh

EXPOSE 8081

ENTRYPOINT ["/app/docker/entrypoint.gcsfuse.sh"]
